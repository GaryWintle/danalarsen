---
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'

interface Props {
  /** Anchor id — must match the era's entry in the timeline rail */
  id: string
  /** Era heading */
  title: string
  /** Date badge under the heading, e.g. "1994–2004" */
  years: string
  /** Large watermark year; defaults to the first 4-digit year in `years` */
  ghost?: string
  /** Era photo — omit to render a gray placeholder block */
  image?: ImageMetadata
  imageAlt?: string
}

const { id, title, years, image, imageAlt } = Astro.props
const ghost = Astro.props.ghost ?? years.match(/\d{4}/)?.[0] ?? years
---

<article class="era" id={id}>
  <span class="era-ghost" aria-hidden="true">{ghost}</span>

  {
    image ? (
      <Image
        class="era-media"
        src={image}
        alt={imageAlt ?? ''}
        width={896}
        loading="lazy"
      />
    ) : (
      <div
        class="era-media media-placeholder"
        role="img"
        aria-label={`Placeholder for a photo: ${title}`}
      >
        <span>Photo placeholder</span>
      </div>
    )
  }

  <p class="era-years">{years}</p>

  <h2>{title}</h2>

  <div class="era-body">
    <slot />
  </div>
</article>

<style>
  .era {
    position: relative;
    scroll-margin-top: 7rem;
    display: flex;
    flex-direction: column;
    gap: var(--sp-04);
  }

  .era-ghost {
    position: absolute;
    top: -0.35em;
    right: 0;
    z-index: -1;
    font-family: var(--font-header);
    font-size: clamp(5rem, 12vw, 9rem);
    line-height: 1;
    color: var(--surface-tint);
    user-select: none;
    pointer-events: none;
  }

  .era-media {
    aspect-ratio: 4 / 3;
    width: min(100%, 28rem);
    object-fit: cover;
    border-radius: var(--br-02);
  }

  .media-placeholder {
    display: grid;
    place-items: center;
    background: var(--surface-tint);
    border: 1px dashed var(--border-color);
  }

  .media-placeholder span {
    font-family: var(--font-body);
    font-size: var(--font-01);
    color: var(--text-strong);
  }

  h2 {
    font-size: clamp(1.4375rem, 2.5vw, 1.75rem);
    /* pull the headline snug against its eyebrow (flex gap is 1rem) */
    margin-block-start: calc(-1 * var(--sp-02));
  }

  /* Year as an eyebrow above the headline: short orange tick + tracked
     caps, echoing the page kicker and the rail's active-year orange */
  .era-years {
    display: flex;
    align-items: center;
    gap: var(--sp-02);
    margin-block-start: var(--sp-02);
    font-family: var(--font-body);
    font-size: var(--font-01);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent-warm);
  }

  .era-years::before {
    content: '';
    width: 1.25rem;
    height: 3px;
    border-radius: 1.5px;
    background: var(--accent-warm);
  }

  .era-body {
    display: flex;
    flex-direction: column;
    gap: var(--sp-04);
  }

  /* Body copy is slotted from the page, so it needs :global */
  .era-body :global(p) {
    max-width: 60ch;
  }

  /* Soft rise-in on first reveal. The hidden state is only ever applied by
     the page script (and only to below-fold blocks), so content stays
     visible without JS. Removed entirely under reduced motion. */
  @media (prefers-reduced-motion: no-preference) {
    .era.will-reveal {
      opacity: 0;
      translate: 0 1.5rem;
      transition:
        opacity 600ms ease-out,
        translate 600ms ease-out;
    }

    .era.will-reveal.in-view {
      opacity: 1;
      translate: 0 0;
    }
  }

  @media (max-width: 60rem) {
    .era {
      scroll-margin-top: 5rem;
    }

    .era-media {
      width: 100%;
    }

    .era-ghost {
      font-size: 4rem;
      top: auto;
      bottom: 100%;
    }
  }
</style>
