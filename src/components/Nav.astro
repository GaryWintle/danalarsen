---
import Logo from '@graphics/dl-logo.svg?raw'
import Facebook from '@graphics/socials/facebook-base.svg?raw'
import Instagram from '@graphics/socials/instagram-base.svg?raw'
import X from '@graphics/socials/x-base.svg?raw'
---

<nav aria-label="Primary navigation">
  <a href="/" class="logo-link" aria-label="Dana Larsen - Return to homepage">
    <div class="logo" set:html={Logo} /></a
  >

  <div class="navigation">
    <ul class="links">
      <li><a class="nav-link" href="#projects">Projects</a></li>
      <li><a class="nav-link" href="#about">About</a></li>
      <li><a class="nav-link" href="/contact">Contact</a></li>
    </ul>
    <ul class="links social-group">
      <li>
        <a
          href="https://facebook.com/danalarsen"
          aria-label="Follow Dana Larsen on Facebook"
          rel="noopener noreferrer"
          target="_blank"><div class="social-icon" set:html={Facebook} /></a
        >
      </li>
      <li>
        <a
          href="https://instagram.com/danalarsen"
          aria-label="Follow Dana Larsen on Instagram"
          rel="noopener noreferrer"
          target="_blank"><div class="social-icon" set:html={Instagram} /></a
        >
      </li>
      <li>
        <a
          href="https://x.com/danalarsen"
          aria-label="Follow Dana Larsen on X (formerly Twitter)"
          rel="noopener noreferrer"
          target="_blank"><div class="social-icon" set:html={X} /></a
        >
      </li>
    </ul>
  </div>

  <button
    class="menu-toggle"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="mobile-drawer"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      <line x1="3" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      <line x1="3" y1="18" x2="21" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>
</nav>

<!-- Mobile Drawer -->
<div class="mobile-drawer" id="mobile-drawer" aria-hidden="true" role="dialog" aria-label="Navigation menu">
  <div class="drawer-header">
    <a href="/" class="drawer-logo" aria-label="Dana Larsen - Return to homepage">
      <div set:html={Logo} />
    </a>
    <button class="drawer-close" aria-label="Close menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <line x1="4" y1="4" x2="20" y2="20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <line x1="20" y1="4" x2="4" y2="20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <ul class="drawer-links">
    <li><a class="drawer-link" href="#projects">Projects</a></li>
    <li><a class="drawer-link" href="#about">About</a></li>
    <li><a class="drawer-link" href="/contact">Contact</a></li>
    <li><a class="drawer-link" href="#newsletter">Newsletter</a></li>
  </ul>

  <div class="drawer-footer">
    <p class="drawer-follow">Follow Dana</p>
    <ul class="drawer-socials">
      <li>
        <a href="https://facebook.com/danalarsen" aria-label="Follow Dana Larsen on Facebook" rel="noopener noreferrer" target="_blank">
          <div set:html={Facebook} />
        </a>
      </li>
      <li>
        <a href="https://instagram.com/danalarsen" aria-label="Follow Dana Larsen on Instagram" rel="noopener noreferrer" target="_blank">
          <div set:html={Instagram} />
        </a>
      </li>
      <li>
        <a href="https://x.com/danalarsen" aria-label="Follow Dana Larsen on X (formerly Twitter)" rel="noopener noreferrer" target="_blank">
          <div set:html={X} />
        </a>
      </li>
    </ul>
  </div>
</div>

<div class="drawer-backdrop" aria-hidden="true"></div>

<script>
  const toggle = document.querySelector('.menu-toggle') as HTMLButtonElement
  const drawer = document.getElementById('mobile-drawer') as HTMLElement
  const backdrop = document.querySelector('.drawer-backdrop') as HTMLElement
  const closeBtn = drawer.querySelector('.drawer-close') as HTMLButtonElement
  const drawerLinks = drawer.querySelectorAll('.drawer-link')

  function openDrawer() {
    drawer.classList.add('is-open')
    backdrop.classList.add('is-open')
    toggle.setAttribute('aria-expanded', 'true')
    drawer.setAttribute('aria-hidden', 'false')
    closeBtn.focus()
    document.body.style.overflow = 'hidden'
  }

  function closeDrawer() {
    drawer.classList.remove('is-open')
    backdrop.classList.remove('is-open')
    toggle.setAttribute('aria-expanded', 'false')
    drawer.setAttribute('aria-hidden', 'true')
    toggle.focus()
    document.body.style.overflow = ''
  }

  toggle.addEventListener('click', openDrawer)
  closeBtn.addEventListener('click', closeDrawer)
  backdrop.addEventListener('click', closeDrawer)

  drawerLinks.forEach(link => {
    link.addEventListener('click', closeDrawer)
  })

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer.classList.contains('is-open')) {
      closeDrawer()
    }
  })
</script>

<style>
  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: absolute;
    width: var(--max-width);
    padding-inline-end: var(--section-inline);
    padding-inline-start: calc(var(--section-inline) / 2);
    padding-block: var(--sp-04);
    z-index: 5;
  }
  .navigation {
    display: flex;
    align-items: center;
    gap: var(--sp-06);
  }
  .logo {
    width: 12rem;
  }
  .links {
    display: flex;
    gap: var(--sp-06);
  }
  .social-group {
    gap: var(--sp-01);
  }
  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 0.5rem;
    margin: -0.75rem -0.5rem;
    font-family: var(--font-body);
    font-size: var(--font-02);
    color: var(--button-text);
    letter-spacing: 0.02rem;
    text-decoration: none;
    font-weight: var(--font-weight-semibold);
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.25rem;

    height: 2px;
    background-color: var(--blue-200);

    transform: scaleX(0);
    transform-origin: left;

    transition: transform 220ms cubic-bezier(0.85, 0.09, 0.15, 0.91);
  }

  .nav-link:focus-visible {
    outline: var(--focus-ring);
    outline-offset: 4px;
    border-radius: 4px;
  }

  .nav-link:hover::after,
  .nav-link:focus-visible::after {
    transform: scaleX(1);
  }

  /* Hamburger toggle */
  .menu-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--blue-100);
    cursor: pointer;
    padding: var(--sp-02);
    margin: calc(var(--sp-02) * -1);
    border-radius: var(--br-02);
    transition: opacity 200ms ease;
  }
  .menu-toggle:hover {
    opacity: 0.75;
  }
  .menu-toggle:focus-visible {
    outline: var(--focus-ring);
    outline-offset: 4px;
  }

  /* Drawer */
  .mobile-drawer {
    position: fixed;
    top: 0;
    right: 0;
    width: 88%;
    height: 100dvh;
    background: var(--blue-300);
    display: flex;
    flex-direction: column;
    padding: var(--sp-04) var(--section-inline);
    padding-block-end: var(--layout-02);
    transform: translateX(100%);
    transition: transform 400ms cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 200;
    overflow-y: auto;
  }
  .mobile-drawer.is-open {
    transform: translateX(0);
  }

  .drawer-backdrop {
    position: fixed;
    inset: 0;
    background: oklch(from var(--blue-300) 20% c h / 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 400ms ease;
    z-index: 199;
  }
  .drawer-backdrop.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: 0;
  }

  .drawer-logo {
    width: 10rem;
    display: block;
  }

  .drawer-close {
    background: none;
    border: none;
    color: var(--neutral-100);
    cursor: pointer;
    padding: var(--sp-02);
    margin: calc(var(--sp-02) * -1);
    border-radius: var(--br-02);
    transition: opacity 200ms ease;
  }
  .drawer-close:hover {
    opacity: 0.7;
  }
  .drawer-close:focus-visible {
    outline: var(--focus-ring);
    outline-offset: 4px;
  }

  .drawer-links {
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex: 1;
    gap: 0;
  }

  .drawer-link {
    font-family: var(--font-header);
    font-size: 4.8rem;
    color: var(--neutral-100);
    text-decoration: none;
    padding-block: var(--sp-05);
    border-bottom: 1px solid oklch(from var(--neutral-100) l c h / 0.15);
    display: block;
    transition: color 200ms ease, letter-spacing 200ms ease;
    letter-spacing: -1px;
    line-height: 1.1;
  }
  .drawer-link:hover,
  .drawer-link:focus-visible {
    color: var(--blue-100);
    letter-spacing: 1px;
  }
  .drawer-link:focus-visible {
    outline: var(--focus-ring);
    outline-offset: 4px;
    border-radius: var(--br-01);
  }

  .drawer-footer {
    display: flex;
    flex-direction: column;
    gap: var(--sp-04);
    padding-block-start: var(--layout-01);
  }

  .drawer-follow {
    font-family: var(--font-body);
    font-size: var(--font-01);
    font-weight: var(--font-weight-semibold);
    color: oklch(from var(--neutral-100) l c h / 0.45);
    letter-spacing: 0.1rem;
    text-transform: uppercase;
  }

  .drawer-socials {
    display: flex;
    gap: var(--sp-03);
  }

  .drawer-socials a {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-04);
    border-radius: var(--br-02);
    color: var(--neutral-100);
    transition: opacity 200ms ease;
  }

  .drawer-socials :global(svg) {
    width: 3.4rem;
    height: 3.4rem;
  }
  .drawer-socials a:hover {
    opacity: 0.7;
  }
  .drawer-socials a:focus-visible {
    outline: var(--focus-ring);
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .navigation {
      display: none;
    }
    .menu-toggle {
      display: flex;
    }
    .logo {
      width: 10rem;
    }
  }
</style>
