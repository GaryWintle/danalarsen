---
import Layout from '@layouts/Layout.astro'
import Nav from '@components/Nav.astro'
import Footer from '@components/Footer.astro'
import BackToTop from '@components/BackToTop.astro'
import Button from '@components/Button.astro'
import TimelineEra from '@components/TimelineEra.astro'
import { getImage, Image } from 'astro:assets'
import aboutImage from '@images/image-about-page-header.png'
import cannabisCultureImage from '@images/about-timeline/about-cannabisculture.png'
import bcMarijuanaPartyImage from '@images/about-timeline/about-bcmarijuanaparty.jpg'
import dispensaryImage from '@images/about-timeline/about-cannabisdispensary.jpeg'
import sensibleBcImage from '@images/about-timeline/about-sensiblebc.jpg'
import drugTestingImage from '@images/about-timeline/about-getyourdrugstested.jpg'
import mushroomDispensaryImage from '@images/about-timeline/about-mushroomdispensary.webp'
import fightContinuesImage from '@images/about-timeline/about-fight-continues.jpg'
import splash01Image from '@images/about-timeline/about-splash01.webp'
import splash02Image from '@images/about-timeline/about-splash02.jpg'

const fillerCopy = [
  'Lorem ipsum dolor sit amet consectetur. Fames nec semper duis viverra. Viverra volutpat nascetur est quis enim sit. Nulla dignissim duis porta sodales iaculis tellus hendrerit, lobortis tortor elementum pellentesque diam varius faucibus et id ipsum.',
  'Non nam aenean nullam lorem. Sociis et eget euismod mauris donec integer eget egestas. Gravida turpis nunc eget felis magna sapien amet, egestas sodales eget id aliquam id suspendisse.',
]

// The single source of truth for the timeline: each entry renders one
// <TimelineEra> block AND one rail entry, so they can never drift apart.
//   id     — anchor (rail links to #id)
//   years  — date badge in the block AND the rail ("sub-title")
//   label  — short rail text (block title used if you omit it)
//   title  — era heading
//   body   — paragraphs for the block (swap fillerCopy for real copy)
//   image  — optional: import a photo above and set image/imageAlt here
// TODO: dates and titles are placeholders — verify every one with Dana
// before launch.
const eras = [
  {
    id: 'cannabis-culture',
    years: '1994–2004',
    label: 'Editor of Cannabis Culture Magazine',
    title: 'Editor of Cannabis Culture Magazine',
    body: fillerCopy,
    image: cannabisCultureImage,
    imageAlt:
      "Cover of Cannabis Culture Magazine, 'The Magazine of the Marijuana Millennium'",
  },
  {
    id: 'bc-marijuana-party',
    years: '2001',
    label: 'Co-founds the BC Marijuana Party',
    title: 'Co-founds the BC Marijuana Party',
    body: fillerCopy,
    image: bcMarijuanaPartyImage,
    imageAlt:
      'Cannabis Culture headquarters signage for the BC Marijuana Party',
  },
  {
    id: 'dispensary',
    years: '2008',
    label: 'The Medicinal Cannabis Dispensary',
    title: 'Opens The Medicinal Cannabis Dispensary',
    body: fillerCopy,
    image: dispensaryImage,
    imageAlt:
      'Dana Larsen holding cannabis at The Medicinal Cannabis Dispensary',
  },
  {
    id: 'sensible-bc',
    years: '2013',
    label: 'Sensible BC campaign',
    title: 'Leads the Sensible BC referendum campaign',
    body: fillerCopy,
    image: sensibleBcImage,
    imageAlt:
      "Dana Larsen speaking at a Sensible BC 'Decriminalize Cannabis' campaign event",
  },
  {
    id: 'drug-testing',
    years: '2019',
    label: 'Get Your Drugs Tested',
    title: 'Launches Get Your Drugs Tested',
    body: fillerCopy,
    image: drugTestingImage,
    imageAlt: 'Dana Larsen outside the Get Your Drugs Tested storefront',
  },
  {
    id: 'mushroom-dispensary',
    years: '2019',
    label: 'The Medicinal Mushroom Dispensary',
    title: 'Opens The Medicinal Mushroom Dispensary',
    body: fillerCopy,
    image: mushroomDispensaryImage,
    imageAlt:
      'Dana Larsen holding permits outside the Medicinal Mushroom Dispensary',
  },
  {
    id: 'today',
    years: 'Today',
    ghost: 'Now',
    label: 'The fight continues...',
    title: 'The fight continues...',
    body: fillerCopy,
    image: fightContinuesImage,
    imageAlt:
      'Dana Larsen lighting a cigarette on a rooftop at dusk, city towers in the background',
  },
]

// Social-share card for this page: Dana's header photo instead of the
// site-wide default, cropped to the OG 1200x630 canvas
const ogImg = await getImage({
  src: aboutImage,
  width: 1200,
  height: 630,
  fit: 'cover',
  format: 'jpeg',
})
---

<Layout
  title="About Dana Larsen | Canadian Drug Policy Reform Activist"
  description="Three decades of drug policy activism: from editing Cannabis Culture Magazine to founding dispensaries, drug-testing services, and reform campaigns across Canada."
  url="https://www.danalarsen.com/about"
  schemaType="AboutPage"
  ogImage={`https://www.danalarsen.com${ogImg.src}`}
>
  <Nav variant="onlight" />
  <main id="main-content" class="about-page">
    <header class="page-header">
      <p class="kicker">About</p>
      <h1>Dana Larsen</h1>
    </header>

    <div class="page-body">
      <div class="hero-media">
        <Image
          src={aboutImage}
          width={1200}
          widths={[640, 960, 1200]}
          sizes="(max-width: 67.5rem) 100vw, 62.25rem"
          format="webp"
          alt="Dana Larsen speaking with media outside a Vancouver courthouse"
          class="about-image-header"
          loading="eager"
          fetchpriority="high"
        />
      </div>

      <p class="statement">
        Dana Larsen is one of Canada’s most well-known advocates for cannabis
        reform and an end to the global war on drugs.
      </p>

      <section id="career" class="career" aria-label="Career history">
        <div class="era-list">
          {
            eras.map((era) => (
              <TimelineEra
                id={era.id}
                years={era.years}
                ghost={era.ghost}
                title={era.title}
                image={era.image}
                imageAlt={era.imageAlt}
              >
                {era.body.map((para) => (
                  <p>{para}</p>
                ))}
              </TimelineEra>
            ))
          }
        </div>

        <nav class="timeline-rail" aria-label="Career timeline">
          <p class="rail-title">Dana’s Career Timeline</p>
          <div class="rail-track" aria-hidden="true">
            <div class="rail-fill"></div>
          </div>
          <ol class="rail-list">
            {
              eras.map((era, i) => (
                <li>
                  <a
                    class="rail-link"
                    href={`#${era.id}`}
                    aria-current={i === 0 ? 'location' : undefined}
                  >
                    <span class="rail-years">{era.years}</span>
                    <span class="rail-label">{era.label}</span>
                  </a>
                </li>
              ))
            }
          </ol>
        </nav>
      </section>
    </div>

    <section class="photo-band" aria-label="Photos of Dana in the field">
      <div class="photo-band-inner">
        <figure class="band-quote">
          <blockquote>
            <p>“I want to see cannabis growing openly from coast to coast.”</p>
          </blockquote>
          <figcaption>— Dana Larsen</figcaption>
        </figure>
        <Image
          src={splash01Image}
          width={1000}
          widths={[500, 750, 1000]}
          sizes="(max-width: 60rem) min(100vw, 30rem), 41rem"
          format="webp"
          alt="Dana Larsen outside a cannabis dispensary, backlit green signage behind him"
          class="band-media band-media-top"
          loading="lazy"
        />
        <Image
          src={splash02Image}
          width={1180}
          widths={[590, 885, 1180]}
          sizes="(max-width: 60rem) min(100vw, 30rem), 43rem"
          format="webp"
          alt="Dana Larsen speaking at a protest, flanked by police and fellow demonstrators"
          class="band-media band-media-bottom"
          loading="lazy"
        />
      </div>
    </section>

    <section class="about-cta" aria-labelledby="about-cta-heading">
      <div class="cta-inner">
        <h2 id="about-cta-heading">Reach out to Dana!</h2>
        <p>
          Booking an event or working on a piece about drug policy? We read
          every message coming our way.
        </p>
        <div class="cta-actions">
          <Button color="primary" href="/contact">Contact Dana</Button>
          <!-- Text link, not a secondary button: on this dark band a
               blue button would blend into the background -->
          <a class="cta-link" href="/news">See Dana in the Media</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <BackToTop />
</Layout>

<style>
  .about-page {
    padding-block-start: calc(var(--section-block) - 2rem);
  }

  .page-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-02);
    padding-block: var(--layout-02) var(--layout-01);
    text-align: center;
  }

  .kicker {
    font-family: var(--font-body);
    font-size: var(--font-01);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .page-header h1 {
    color: var(--text-title);
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    letter-spacing: -1px;
    line-height: 1.1;
  }

  .page-body {
    width: min(100%, var(--section-width));
    padding-inline: var(--section-inline);
    display: flex;
    flex-direction: column;
  }
  .hero-media {
    /* aspect-ratio: 21 / 9; */
    width: 100%;
    overflow: hidden;
    border-radius: var(--br-02);
  }

  .about-image-header {
    width: 100%;
    /* height: min(100%, 800px); */
    object-fit: cover;
    /* faces slightly right-of-center in the source — keep the crop there */
    object-position: 62% center;
  }

  .statement {
    font-family: var(--font-header);
    color: var(--text-title);
    font-size: clamp(1.75rem, 3.5vw, 3.75rem);
    line-height: 1.2;
    letter-spacing: -0.5px;
    text-wrap: balance;
    max-width: 100%;
    padding-block: var(--layout-03);
  }

  /* ---------------- Career timeline ---------------- */

  .career {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 16rem;
    gap: var(--layout-03);
    align-items: start;
  }

  .era-list {
    display: flex;
    flex-direction: column;
    gap: var(--section-block);
    min-width: 0;
  }

  /* ---------------- Sticky rail ---------------- */

  .timeline-rail {
    position: sticky;
    top: 7rem;
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: var(--sp-04);
    padding-block: var(--sp-02);
  }

  .rail-title {
    grid-column: 1 / -1;
    font-family: var(--font-header);
    font-style: italic;
    font-size: var(--font-03);
    color: var(--text-title);
    margin-block-end: var(--sp-05);
  }

  .rail-track {
    grid-row: 2;
    grid-column: 1;
    position: relative;
    width: 2px;
    background: var(--border-color);
    border-radius: 1px;
  }

  .rail-fill {
    position: absolute;
    inset: 0;
    background: var(--orange-300);
    border-radius: inherit;
    transform: scaleY(var(--progress, 0));
    transform-origin: top;
  }

  .rail-list {
    grid-row: 2;
    grid-column: 2;
    display: flex;
    flex-direction: column;
    gap: var(--sp-05);
  }

  .rail-link {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    text-decoration: none;
  }

  /* Node dot sits on the track to the left of the label column. The
     bg-page ring lifts it cleanly off the fill line. */
  .rail-link::before {
    content: '';
    position: absolute;
    top: 0.3125rem;
    left: calc(-1 * var(--sp-04) - 5px);
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border-color);
    box-shadow: 0 0 0 3px var(--bg-page);
    transition:
      background-color 250ms ease,
      scale 250ms ease;
  }

  .rail-link.passed::before {
    background: var(--orange-300);
  }

  .rail-link.passed .rail-years {
    color: var(--text-strong);
  }

  .rail-years {
    font-family: var(--font-body);
    font-size: var(--font-01);
    font-weight: var(--font-weight-semibold);
    color: var(--text-muted);
    transition: color 250ms ease;
  }

  .rail-label {
    font-family: var(--font-body);
    font-size: var(--font-01);
    line-height: 1.35;
    color: var(--text-muted);
    transition: color 250ms ease;
  }

  .rail-link:hover .rail-years,
  .rail-link:hover .rail-label {
    color: var(--text-link);
  }

  .rail-link:focus-visible {
    outline: var(--focus-ring);
    outline-offset: 4px;
    border-radius: var(--br-01);
  }

  .rail-link[aria-current='location'] .rail-years {
    color: var(--accent-warm);
  }

  .rail-link[aria-current='location'] .rail-label {
    color: var(--text-strong);
  }

  .rail-link[aria-current='location']::before {
    background: var(--orange-300);
    scale: 1.4;
  }

  /* ---------------- Photo band ----------------
     Breaks out of .page-body's narrower --section-width on purpose — the
     one place on the page allowed a wider, editorial stance. Two landscape
     photos interlock diagonally: the middle grid row is a shared "overlap
     strip" both photos span, so the stagger is deterministic — no negative
     margins to fight at odd viewport sizes. The pull-quote sits in the
     whitespace the stagger carves out. */

  .photo-band {
    width: 100%;
    padding-block: var(--section-block);
  }

  .photo-band-inner {
    width: min(100%, 88rem);
    margin-inline: auto;
    padding-inline: var(--section-inline);
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    grid-template-rows: auto clamp(3.5rem, 8vw, 6.5rem) auto;
    column-gap: var(--layout-02);
  }

  .band-media {
    width: 100%;
    object-fit: cover;
    height: auto; /* required alongside aspect-ratio — see TimelineEra.astro */
    border-radius: var(--br-02);
    box-shadow: var(--shadow-deep);
  }

  .band-media-top {
    grid-column: 2;
    grid-row: 1 / 3;
    aspect-ratio: 3 / 2;
    align-self: start;
  }

  .band-media-bottom {
    grid-column: 1;
    grid-row: 2 / 4;
    aspect-ratio: 4 / 3;
    align-self: start;
  }

  .band-quote {
    grid-column: 1;
    grid-row: 1;
    justify-self: end;
    align-self: center;
    text-align: right;
    max-width: 30ch;
    padding-block: var(--layout-01);
  }

  .band-quote p {
    font-family: var(--font-header);
    font-style: italic;
    font-size: clamp(1.5rem, 2.2vw, 2rem);
    line-height: 1.4;
    color: var(--text-title);
    text-wrap: balance;
  }

  .band-quote figcaption {
    margin-block-start: var(--sp-04);
    font-family: var(--font-body);
    font-size: var(--font-01);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* Soft rise-in, matching the timeline's own reveal treatment */
  @media (prefers-reduced-motion: no-preference) {
    .photo-band.will-reveal {
      opacity: 0;
      translate: 0 1.5rem;
      transition:
        opacity 600ms ease-out,
        translate 600ms ease-out;
    }

    .photo-band.will-reveal.in-view {
      opacity: 1;
      translate: 0 0;
    }
  }

  /* ---------------- Closing CTA ---------------- */

  .about-cta {
    width: 100%;
    background: linear-gradient(
      oklch(from var(--surface-dark) calc(l + 0.05) c h),
      var(--surface-dark)
    );
    display: grid;
    place-items: center;
    padding-block: var(--layout-03);
    padding-inline: var(--section-inline);
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-04);
    text-align: center;
  }

  .about-cta h2 {
    color: var(--text-title-ondark);
  }

  .about-cta p {
    color: var(--text-body-ondark);
    max-width: 45ch;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--sp-05);
    margin-block-start: var(--sp-03);
  }

  .cta-link {
    font-family: var(--font-body);
    font-size: var(--font-02);
    font-weight: var(--font-weight-semibold);
    color: var(--text-title-ondark);
    text-decoration: underline;
    text-underline-offset: 4px;
    padding: var(--sp-03) var(--sp-02);
  }

  .cta-link:hover {
    color: var(--accent);
  }

  .cta-link:focus-visible {
    outline: var(--focus-ring);
    outline-offset: 4px;
    border-radius: var(--br-01);
  }

  /* ---------------- Mobile ---------------- */

  @media (max-width: 60rem) {
    .career {
      grid-template-columns: 1fr;
      gap: 0;
    }

    /* The rail becomes a sticky horizontal year bar above the eras */
    .timeline-rail {
      order: -1;
      top: 0;
      z-index: 10;
      grid-template-columns: 1fr;
      background: oklch(from var(--bg-page) l c h / 0.92);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      margin-inline: calc(-1 * var(--section-inline));
      padding-inline: var(--section-inline);
      padding-block: var(--sp-03) 0;
    }

    .rail-title {
      display: none;
    }

    .rail-list {
      grid-row: 1;
      grid-column: 1;
      flex-direction: row;
      gap: var(--sp-05);
      overflow-x: auto;
      scrollbar-width: none;
      padding-block-end: var(--sp-03);
    }

    .rail-list::-webkit-scrollbar {
      display: none;
    }

    .rail-link::before {
      display: none;
    }

    .rail-link {
      white-space: nowrap;
    }

    .rail-label {
      display: none;
    }

    .rail-years {
      font-size: var(--font-02);
    }

    .rail-track {
      grid-row: 2;
      grid-column: 1;
      width: 100%;
      height: 2px;
    }

    .rail-fill {
      transform: scaleX(var(--progress, 0));
      transform-origin: left;
    }

    .era-list {
      padding-block-start: var(--layout-02);
      gap: var(--layout-03);
    }

    /* Single column: photo, quote, photo — the interlock rows collapse */
    .photo-band-inner {
      grid-template-columns: 1fr;
      grid-template-rows: none;
      row-gap: var(--layout-02);
    }

    .band-media-top {
      grid-column: 1;
      grid-row: auto;
      order: -1;
      justify-self: center;
      max-width: 30rem;
      aspect-ratio: 4 / 3;
    }

    .band-media-bottom {
      grid-column: 1;
      grid-row: auto;
      justify-self: center;
      max-width: 30rem;
    }

    .band-quote {
      grid-column: 1;
      grid-row: auto;
      justify-self: center;
      text-align: center;
      max-width: 34ch;
      padding-block: var(--sp-04);
    }

    .band-quote p {
      font-size: var(--font-04);
    }
  }
</style>

<script>
  const career = document.getElementById('career') as HTMLElement
  const rail = document.querySelector('.timeline-rail') as HTMLElement
  const railList = document.querySelector('.rail-list') as HTMLElement
  const links = [
    ...document.querySelectorAll('.rail-link'),
  ] as HTMLAnchorElement[]
  const eras = [...document.querySelectorAll('.era')] as HTMLElement[]
  const reduceMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)',
  ).matches

  // Fill the rail in proportion to reading progress through the section
  let ticking = false
  const updateProgress = () => {
    const rect = career.getBoundingClientRect()
    const anchor = window.innerHeight * 0.5
    const progress = Math.min(1, Math.max(0, (anchor - rect.top) / rect.height))
    rail.style.setProperty('--progress', progress.toFixed(4))
    ticking = false
  }
  window.addEventListener(
    'scroll',
    () => {
      if (!ticking) {
        ticking = true
        requestAnimationFrame(updateProgress)
      }
    },
    { passive: true },
  )
  updateProgress()

  // Highlight the era currently in the middle of the viewport; eras
  // already read get the "passed" treatment
  const setActive = (id: string) => {
    const activeIndex = links.findIndex((link) => link.hash === `#${id}`)
    links.forEach((link, i) => {
      link.classList.toggle('passed', i < activeIndex)
      if (i === activeIndex) {
        link.setAttribute('aria-current', 'location')
        // Keep the active chip visible when the rail is a horizontal bar
        railList.scrollTo({
          left:
            link.offsetLeft - railList.clientWidth / 2 + link.offsetWidth / 2,
          behavior: reduceMotion ? 'auto' : 'smooth',
        })
      } else {
        link.removeAttribute('aria-current')
      }
    })
  }

  const activeWatcher = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) setActive(entry.target.id)
      })
    },
    { rootMargin: '-45% 0px -45% 0px' },
  )
  eras.forEach((era) => activeWatcher.observe(era))

  // One-time rise-in reveal for blocks below the fold. Blocks already on
  // screen at load are left untouched so nothing flashes. The huge top
  // rootMargin means anything the user has jumped past (PgDn, scrollbar
  // drag) still counts as revealed — content can never stay hidden.
  const revealWatcher = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view')
          revealWatcher.unobserve(entry.target)
        }
      })
    },
    { threshold: 0.15, rootMargin: '9999px 0px 0px 0px' },
  )
  const photoBand = document.querySelector('.photo-band') as HTMLElement | null
  const revealCandidates = photoBand ? [...eras, photoBand] : eras
  if (!reduceMotion) {
    revealCandidates.forEach((el) => {
      if (el.getBoundingClientRect().top > window.innerHeight) {
        el.classList.add('will-reveal')
        revealWatcher.observe(el)
      }
    })
  }
</script>
