---
import Layout from '@layouts/Layout.astro'
import Nav from '@components/Nav.astro'
import ContactForm from '@components/ContactForm.astro'
import Footer from '@components/Footer.astro'
import { Image } from 'astro:assets'
import headerImage from '@images/image-about-page-header.png'
---

<Layout
  title="Contact Dana Larsen"
  description="Get in touch with Dana Larsen for speaking engagements, media inquiries, or general questions."
  url="https://www.danalarsen.com/contact"
  schemaType="ContactPage"
>
  <Nav variant="onlight" />
  <main id="main-content" class="contact-page">
    <div class="contact-wrapper">
      <ContactForm />
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .contact-page {
    width: 100%;
    display: grid;
    place-items: center;
    padding-block: var(--section-block);
    padding-inline: var(--section-inline);
    min-height: 80vh;
  }

  .contact-wrapper {
    width: min(100%, 50rem);
  }

  @media (max-width: 48rem) {
    /* Full-bleed card on phones: edge to edge with no page background framing
       it. The top clears the absolute-positioned nav (dark-on-light) so the
       dark hero doesn't collide with it; the sides run to the screen edges and
       the bottom butts straight against the footer. */
    .contact-page {
      padding: 5.5rem 0 0;
      min-height: 0;
    }
  }
</style>
