---
import { getImage } from 'astro:assets'
import Button from '@components/Button.astro'
import aboutImage from '@images/danalarsen-about.webp'

const optimizedBackground = await getImage({ src: aboutImage, format: 'webp' })
const optimizedPhoto = await getImage({
  src: aboutImage,
  format: 'webp',
  width: 700,
})
---

<section
  id="about"
  class="about"
  aria-labelledby="about-heading"
  style={`--about-bg: url(${optimizedBackground.src})`}
>
  <div class="about-container">
    <div class="about-card">
      <div class="about-copy">
        <div class="about-text-wrapper">
          <h2 id="about-heading">
            Meet Dana Larsen, Canada's Leader in Drug Policy Revolution.
          </h2>
          <p>
            Lorem ipsum dolor sit amet consectetur. Nisl faucibus non magna
            ipsum. Lorem ipsum dolor sit amet consectetur. Nisl faucibus non
            magna ipsum.
          </p>
        </div>
        <div class="button-wrapper">
          <Button color="primary">More about Dana</Button>
        </div>
      </div>
    </div>
    <img
      src={optimizedPhoto.src}
      alt="Dana Larsen"
      class="about-image"
      loading="lazy"
    />
  </div>
</section>

<style>
  p {
    width: min(100%, 55ch);
    margin-block-end: var(--sp-02);
  }

  .about {
    position: relative;
    width: 100%;
    display: grid;
    place-items: center;
    overflow: visible;
    padding-block: var(--section-block);
    z-index: 0;
  }

  .about::before {
    content: '';
    position: absolute;
    inset: 0 0 0 -100vw;
    background: var(--about-bg);
    background-size: cover;
    background-attachment: fixed;
    z-index: -1;
    opacity: 0.06;
  }

  .about::after {
    content: '';
    position: absolute;
    inset: 0 0 0 -100vw;
    background: linear-gradient(
      oklch(from var(--blue-300) 40% c h),
      var(--blue-300)
    );
    z-index: -2;
  }

  .about-container {
    width: var(--max-width);
    padding-inline: var(--section-inline);
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    grid-template-rows: repeat(7, 1fr);
    /* align-items: center; */
  }

  .about-card {
    grid-area: 2 / 4 / 7 / 8;
    background: oklch(from var(--bg-surface) l c h / 0.93);
    border-radius: var(--br-02);
    box-shadow: 10px 10px 10px oklch(from var(--neutral-600) l c h / 0.2);

    transition:
      box-shadow 0.3s ease,
      transform 0.3s ease;
    z-index: 2;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .about-image {
    /* grid-area: 2 / 4 / 7 / 8; */
    grid-area: 1 / 1 / 8 / 5;
    width: 100%;
    max-height: 100%;
    object-fit: cover;
    z-index: 1;
    justify-self: end;
    border-radius: var(--br-02);
    border: 1px solid oklch(from var(--blue-300) 45% c h);
    box-shadow: 10px 10px 10px oklch(from var(--neutral-600) l c h / 0.2);
  }

  .about-text-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--sp-03);
  }

  .about-copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--sp-06);
    padding-inline: 9.6rem;
    padding-block: 7.8rem;
    height: 100%;
  }

  .button-wrapper {
    align-self: end;
    justify-self: end;
  }

  @media (max-width: 768px) {
    .about-container {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
    }

    .about-card {
      grid-column: 1;
      grid-row: 2;
      max-width: 100%;
      border-radius: 0 0 var(--br-02) var(--br-02);
      background: oklch(from var(--bg-surface) l c h / 1);
    }

    .about-image {
      grid-column: 1;
      grid-row: 1;
      justify-self: center;
      max-width: 100%;
      border-radius: var(--br-02) var(--br-02) 0 0;
      border: 0;
      box-shadow: 10px 10px 10px oklch(from var(--neutral-600) l c h / 0.2);
    }

    .about-copy {
      padding-inline: var(--sp-05);
      padding-block: var(--sp-06);
    }

    .button-wrapper {
      width: 100%;
    }

    .button-wrapper :global(a),
    .button-wrapper :global(button) {
      width: 100%;
    }
  }
</style>
