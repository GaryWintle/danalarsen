---
import { getImage, Image } from 'astro:assets'
import Button from '@components/Button.astro'
import aboutImage from '@images/danalarsen-about.webp'

const optimizedBackground = await getImage({ src: aboutImage, format: 'webp' })
---

<section
  id="about"
  class="about"
  aria-labelledby="about-heading"
  style={`--about-bg: url(${optimizedBackground.src})`}
>
  <div class="about-container">
    <div class="about-card">
      <div class="about-copy">
        <div class="about-text-wrapper">
          <h2 id="about-heading">
            Meet Dana Larsen, Canada's Leader in Drug Policy Revolution.
          </h2>
          <p>
            Non nam aenean nullam lorem. Sociis et eget euismod mauris donec
            integer eget egestas. Gravida turpis nunc eget felis magna sapien
            amet, egestas sodales eget id aliquam id suspendisse.
          </p>
        </div>
        <div class="button-wrapper">
          <Button color="primary" href="/about">More about Dana</Button>
        </div>
      </div>
    </div>
    <Image
      src={aboutImage}
      width={700}
      format="webp"
      alt="Dana Larsen"
      class="about-image"
      loading="lazy"
    />
  </div>
</section>

<style>
  p {
    width: min(100%, 55ch);
    margin-block-end: var(--sp-02);
  }

  .about {
    position: relative;
    width: 100%;
    display: grid;
    place-items: center;
    overflow: visible;
    padding-block: var(--section-block);
    z-index: 0;
  }

  .about::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--about-bg);
    background-size: cover;
    background-position: center;
    z-index: -1;
    opacity: 0.06;
  }

  .about::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      oklch(from var(--surface-dark) calc(l - 0.07) c h),
      var(--surface-dark)
    );
    z-index: -2;
  }

  /* Static backdrop: the photo stays pinned to the viewport while content
     scrolls over it — the background-attachment:fixed look, but composited
     (no scroll repaints) and working on iOS. clip-path keeps the fixed
     layer inside this section. Reduced-motion gets the scrolling version. */
  @media (prefers-reduced-motion: no-preference) {
    .about {
      clip-path: inset(0);
    }

    .about::before {
      position: fixed;
    }
  }

  .about-container {
    width: var(--max-width);
    padding-inline: var(--section-inline);
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    grid-template-rows: repeat(7, 1fr);
  }

  .about-card {
    grid-area: 2 / 4 / 7 / 8;
    background: oklch(from var(--bg-surface) l c h / 0.95);
    border-radius: var(--br-02);
    box-shadow: 10px 10px 10px oklch(from var(--neutral-600) l c h / 0.2);
    z-index: 2;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: all 0.3s;
  }

  .about-card:hover {
    background: oklch(from var(--bg-surface) l c h / 1);
  }

  .about-image {
    grid-area: 1 / 1 / 8 / 5;
    width: 100%;
    max-height: 100%;
    object-fit: cover;
    z-index: 1;
    justify-self: end;
    border-radius: var(--br-02);
    border: 1px solid var(--surface-dark);
    box-shadow: 10px 10px 10px oklch(from var(--neutral-600) l c h / 0.2);
  }

  .about-text-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--sp-03);
  }

  .about-copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--sp-06);
    padding-inline: 6rem;
    padding-block: 4.875rem;
    height: 100%;
  }

  .button-wrapper {
    align-self: end;
    justify-self: end;
  }

  @media (max-width: 75rem) {
    .about-image {
      grid-area: 1 / 1 / 8 / 6;
    }

    .about-card {
      grid-area: 2 / 4 / 8 / 8;
    }

    .about-copy {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: var(--sp-06);
      padding-inline: 3.75rem;
      padding-block: 3.125rem;
      height: 100%;
    }
  }

  @media (max-width: 48rem) {
    .about-container {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
    }

    .about-card {
      grid-column: 1;
      grid-row: 2;
      max-width: 100%;
      border-radius: 0 0 var(--br-02) var(--br-02);
      background: oklch(from var(--bg-surface) l c h / 1);
    }

    .about-image {
      grid-column: 1;
      grid-row: 1;
      justify-self: center;
      max-width: 100%;
      border-radius: var(--br-02) var(--br-02) 0 0;
      border: 0;
      box-shadow: 10px 10px 10px oklch(from var(--neutral-600) l c h / 0.2);
      /* Override the intrinsic height attribute (700x556 landscape source)
         so the photo isn't a full-height 556px slice on phones. A 5:7 box
         is ~22% shorter; object-fit: cover (from the base rule) keeps the
         same face-forward centre framing, just less tall. */
      height: auto;
      aspect-ratio: 3 / 3;
    }

    .about-copy {
      padding-inline: var(--sp-04);
      padding-block: var(--sp-06);
    }

    .button-wrapper {
      width: 100%;
    }

    .button-wrapper :global(a),
    .button-wrapper :global(button) {
      width: 100%;
    }
  }
</style>
