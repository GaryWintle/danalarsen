---
import { getImage } from 'astro:assets'
import Nav from '@components/Nav.astro'
import Button from '@components/Button.astro'
import HeroDivider from '@graphics/hero-divider.svg?raw'
import heroDesktop from '@images/dl-hero-desktop.webp'
import heroMobile from '@images/dl-hero-mobile.webp'

const mobileAvif = await getImage({
  src: heroMobile,
  format: 'avif',
  width: 750,
})
const mobileWebp = await getImage({
  src: heroMobile,
  format: 'webp',
  width: 750,
})
const desktopAvif = await getImage({ src: heroDesktop, format: 'avif' })
const desktopWebp = await getImage({ src: heroDesktop, format: 'webp' })
---

<header aria-label="Hero section">
  <picture class="hero-bg" aria-hidden="true">
    <source
      media="(max-width: 1024px)"
      srcset={mobileAvif.src}
      type="image/avif"
    />
    <source
      media="(max-width: 1024px)"
      srcset={mobileWebp.src}
      type="image/webp"
    />
    <source srcset={desktopAvif.src} type="image/avif" />
    <img src={desktopWebp.src} alt="" fetchpriority="high" />
  </picture>
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="wrapper">
    <div class="content-container">
      <h1>
        <span class="name-highlight">Dana Larsen</span> is an Advocate & Activist
        for Sensible Drug Policy to <span
          class="text-highlight underline-animate">End</span
        > the War on Drugs.
      </h1>
      <div class="buttons-container">
        <Button
          color="secondary"
          href="#about"
          aria-label="Learn more about Dana Larsen's advocacy work"
          class="btn-about">About Dana</Button
        >
        <Button
          color="primary"
          href="/contact"
          aria-label="Contact Dana Larsen to book a speaking engagement"
          >Speak with Dana</Button
        >
      </div>
    </div>

    <div class="hero-divider" set:html={HeroDivider} />
  </div>
</header>

<style>
  header {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    height: max(80rem, 95vh);
    position: relative;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: var(--photo-underglow);
    z-index: 1;
  }

  .wrapper {
    position: relative;
    z-index: 2;
    width: min(100%, var(--max-width));
    height: 100%;
    padding-inline: var(--section-inline);
  }

  .content-container {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: start;
    gap: var(--layout-03);
    width: min(50%, calc(var(--max-width) / 2));
    height: 100%;
  }
  .buttons-container {
    display: flex;
    gap: var(--sp-05);
    padding-inline: var(--sp-02);
  }

  .hero-divider {
    position: absolute;
    bottom: -25px;
    left: 50%;
    width: 100vw;
    transform: translateX(-50%);
    pointer-events: none;
  }
  .hero-divider svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .name-highlight {
    color: var(--blue-100);
  }
  .text-highlight {
    color: var(--blue-100);
    font-style: italic;
    position: relative;
    display: inline-block;
  }
  .underline-animate::after {
    content: '';
    position: absolute;
    left: -4px;
    right: 0;
    bottom: -0.03em;

    height: 3px;
    background-color: currentColor;

    transform: scaleX(0);
    transform-origin: left;
    animation: underline-reveal 700ms cubic-bezier(0.85, 0.09, 0.15, 0.91)
      1000ms forwards;
  }

  @keyframes underline-reveal {
    to {
      transform: scaleX(1);
    }
  }

  /* Tablet */
  @media (max-width: 950px) {
    header {
      width: 100%;
      height: 90dvh;
    }

    .hero-bg img {
      object-position: 90% top;
    }

    .wrapper {
      background: linear-gradient(transparent 70%, rgba(0, 0, 0, 0.849) 95%);
      height: 100%;
      width: 100%;
      padding-inline: var(--section-inline);
    }
    .content-container {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: var(--layout-03);
      padding-block-start: 11rem;
      padding-block-end: 3rem;
      width: 100%;
      height: 100%;
    }
    h1 {
      line-height: 1.2;
    }
    .buttons-container {
      width: 100%;
      display: flex;
      align-self: center;
      gap: var(--sp-05);
      padding-inline: var(--sp-02);
      flex-direction: row;
      justify-self: end;

      padding-block-end: var(--sp-06);
    }

    .hero-divider {
      position: absolute;
      bottom: -15px;
      left: 50%;
      width: 100%;
      transform: translateX(-50%);
      pointer-events: none;
      overflow-x: hidden;
    }
    .hero-divider svg {
      display: block;
      width: 100%;
      height: auto;
    }
  }

  @media (max-width: 1024px) {
    .buttons-container {
      padding-block-end: var(--sp-06);
    }
  }

  @media (max-width: 640px) {
    header {
      display: grid;
      place-items: center;
      width: 100%;
      height: 100dvh;
      position: relative;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      z-index: 0;
    }

    .hero-bg img {
      width: 100%;
      object-fit: cover;
    }

    .buttons-container {
      width: 100%;
      display: flex;
      align-self: center;
      gap: var(--sp-03);
      padding-inline: 0;
      flex-direction: column;
      justify-self: end;
      padding-block-end: 0;
    }
    .hero-divider {
      display: none;
    }

    .buttons-container :global(.btn-about) {
      display: none;
    }
  }
</style>
