---
import danaIcon from '@graphics/dana-headicon.svg?raw'
import weedLeaf from '@graphics/Icons/leaf.svg?raw'
import Button from '@components/Button.astro'
---

<section class="newsletter">
  <div class="newsletter-container">
    <div class="leaf-clip">
      <!-- overflow: hidden lives here -->
      <div class="weed-leaf" set:html={weedLeaf} />
    </div>
    <div class="dana-icon" set:html={danaIcon} />
    <div class="newsletter-text-content">
      <h2 class="newsletter-title">Join the Revolution!</h2>
      <p>
        Sign up for in-depth, informative drug war related updates and join Dana
        in the fight against the war on drugs.
      </p>
    </div>
    <form
      class="newsletter-input"
      aria-labelledby="newsletter-title"
      action="/api/subscribe"
      method="post"
    >
      <label
        for="newsletter-email"
        class="newsletter-input-label visually-hidden"
      >
        Email Address
      </label>

      <input
        id="newsletter-email"
        name="email"
        type="email"
        placeholder="Enter your Email Address"
        required
        autocomplete="email"
        aria-describedby="newsletter-privacy"
      />

      <Button type="submit" aria-label="Subscribe to Dana Larsen's newsletter"
        >Subscibe Today!</Button
      >
    </form>
    <p id="newsletter-privacy" class="fine-print">
      Fully private. No spam. Unsub anytime.
    </p>
  </div>
</section>

<style>
  .newsletter {
    width: 100%;
    display: grid;
    place-items: center;
    padding-block-start: calc(var(--section-block) + 6rem);
    padding-block-end: var(--section-block);
    padding-inline: var(--section-inline);
  }

  .newsletter-container {
    width: var(--max-width);
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--layout-02);
    padding-block-start: var(--layout-03);
    background-color: var(--bg-surface);
    box-shadow: var(--shadow-mid);
    border-radius: var(--br-03);
  }

  .leaf-clip {
    /* background-color: red; */
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: var(--br-03);
  }

  .weed-leaf {
    position: absolute;
    bottom: -15%;
    right: -10%;
    width: 60%;
    opacity: 0.07;
  }

  .weed-leaf :global(svg) {
    width: 100%;
    height: auto;
    display: block;
  }

  .newsletter-container::after {
    content: '';
    /* position: absolute; */
    background-image: url(public/favicon.svg);
  }

  .newsletter-text-content,
  .newsletter-input,
  .fine-print,
  .newsletter-title {
    position: relative;
  }

  .newsletter-text-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-03);
  }

  .dana-icon {
    position: absolute;
    top: -9rem;
    width: 12rem;
    height: auto;
    filter: drop-shadow(0 2px 2px oklch(from var(--blue-300) l c h / 0.1));
  }

  .dana-icon::before,
  .dana-icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 12rem;
    height: 12rem;
    translate: -50% -50%;
    border-radius: 50%;
    border: 2px solid var(--blue-100);
    animation: broadcast 6s ease-out infinite;
  }

  .dana-icon::after {
    animation-delay: 4s;
  }

  @keyframes broadcast {
    0% {
      border: 3px solid var(--blue-100);
      transform: scale(1);
      opacity: 0.35;
    }
    100% {
      border: 1px solid var(--blue-100);
      transform: scale(1.5);
      opacity: 0;
    }
  }

  .newsletter-title {
    margin-block-start: 4rem;
  }

  p {
    width: min(55ch, 100%);
    text-align: center;
  }
  .newsletter-input {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 60%;
    gap: var(--sp-05);
  }

  input {
    width: 80%;
    font-size: var(--font-04);
    font-family: var(--font-body);
    font-weight: var(--font-weight-semibold);
    color: var(--blue-200);
    background-color: oklch(from var(--neutral-100) l c h / 0.7);
    backdrop-filter: blur(8px);
    border: var(--image-border);
    padding: var(--sp-04) var(--sp-04);
    border-radius: var(--br-01);
    text-align: center;
    box-shadow: var(--shadow-shallow);
    transition:
      border-color 0.2s ease,
      box-shadow 0.3s ease;
  }
  input::placeholder {
    color: var(--neutral-400);
  }
  input:focus-visible {
    border: 1px solid var(--blue-200);
    box-shadow: 0 0 0 3px oklch(from var(--blue-200) l c h / 0.2);
  }

  .fine-print {
    font-size: var(--font-01);
    color: var(--neutral-400);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  @media (max-width: 768px) {
    input {
      width: 100%;
      font-size: var(--font-03);
    }

    .newsletter-text-content {
      padding-inline: var(--section-inline);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--sp-03);
    }

    .newsletter-input {
      width: 100%;
      padding-inline: var(--section-inline);
    }

    .weed-leaf {
      position: absolute;
      bottom: -8%;
      right: -45%;
      width: 120%;
      opacity: 0.07;
    }
  }
</style>
