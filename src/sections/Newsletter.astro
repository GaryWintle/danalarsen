---
import danaIcon from '@graphics/dana-headicon.svg?raw'
import weedLeaf from '@graphics/Icons/leaf.svg?raw'
import Button from '@components/Button.astro'
---

<section id="newsletter" class="newsletter">
  <div class="newsletter-container">
    <div class="leaf-clip">
      <!-- overflow: hidden lives here -->
      <div class="weed-leaf" set:html={weedLeaf} />
    </div>
    <div class="dana-icon" set:html={danaIcon} />
    <div class="newsletter-text-content">
      <h2 id="newsletter-title" class="newsletter-title">Join the Revolution!</h2>
      <p>
        Sign up for in-depth, informative drug war related updates and join Dana
        in the fight against the war on drugs.
      </p>
    </div>
    <form
      class="newsletter-input"
      aria-labelledby="newsletter-title"
      name="newsletter"
      method="POST"
      action="/newsletter/thanks"
      data-netlify="true"
      netlify-honeypot="bot-field"
    >
      <input type="hidden" name="form-name" value="newsletter" />

      <p class="visually-hidden" aria-hidden="true">
        <label>
          Leave this field empty
          <input name="bot-field" tabindex="-1" autocomplete="off" />
        </label>
      </p>

      <label
        for="newsletter-email"
        class="newsletter-input-label visually-hidden"
      >
        Email Address
      </label>

      <input
        id="newsletter-email"
        name="email"
        type="email"
        placeholder="Enter your Email Address"
        required
        autocomplete="email"
        aria-describedby="newsletter-privacy"
      />

      <Button type="submit">Subscribe Today!</Button>
    </form>
    <p class="newsletter-status" role="status"></p>
    <p id="newsletter-privacy" class="fine-print">
      Fully private. No spam. Unsub anytime.
      <a class="fine-print-link" href="/privacy">Privacy policy</a>
    </p>
  </div>
</section>

<style>
  .newsletter {
    width: min(100%, var(--section-width));
    display: grid;
    place-items: center;
    padding-block-start: calc(var(--section-block) + 3.75rem);
    padding-block-end: var(--section-block);
    padding-inline: var(--section-inline);
  }

  .newsletter-container {
    width: var(--max-width);
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--layout-02);
    padding-block-start: var(--layout-03);
    background-color: var(--bg-surface);
    box-shadow: var(--shadow-mid);
    border-radius: var(--br-03);
  }

  .leaf-clip {
    /* background-color: red; */
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: var(--br-03);
  }

  .weed-leaf {
    position: absolute;
    bottom: -15%;
    right: -10%;
    width: 60%;
    opacity: 0.1;
  }

  .weed-leaf :global(svg) {
    width: 100%;
    height: auto;
    display: block;
  }

  .newsletter-text-content,
  .newsletter-input,
  .fine-print,
  .newsletter-title {
    position: relative;
  }

  .newsletter-text-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-03);
  }

  .dana-icon {
    position: absolute;
    top: -5.625rem;
    width: 7.5rem;
    height: auto;
    filter: drop-shadow(0 2px 2px oklch(from var(--text-title) l c h / 0.1));
  }

  .dana-icon::before,
  .dana-icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 7.5rem;
    height: 7.5rem;
    translate: -50% -50%;
    border-radius: 50%;
    border: 2px solid var(--accent);
    animation: broadcast 6s ease-out infinite;
  }

  .dana-icon::after {
    animation-delay: 4s;
  }

  /* The rings only exist as animation — hide them entirely without it */
  @media (prefers-reduced-motion: reduce) {
    .dana-icon::before,
    .dana-icon::after {
      display: none;
    }
  }

  @keyframes broadcast {
    0% {
      border: 3px solid var(--accent);
      transform: scale(1);
      opacity: 0.35;
    }
    100% {
      border: 1px solid var(--accent);
      transform: scale(1.5);
      opacity: 0;
    }
  }

  .newsletter-title {
    margin-block-start: 2.5rem;
  }

  p {
    width: min(55ch, 100%);
    text-align: center;
  }
  .newsletter-input {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 60%;
    gap: var(--sp-05);
  }

  input {
    width: 80%;
    font-size: var(--font-04);
    font-family: var(--font-body);
    font-weight: var(--font-weight-semibold);
    color: var(--text-strong);
    background-color: oklch(from var(--bg-surface) l c h / 0.7);
    backdrop-filter: blur(8px);
    border: var(--border-default);
    padding: var(--sp-04) var(--sp-04);
    border-radius: var(--br-01);
    text-align: center;
    box-shadow: var(--shadow-shallow);
    transition:
      border-color 0.2s ease,
      box-shadow 0.3s ease;
  }
  input::placeholder {
    color: var(--text-muted);
  }
  input:focus-visible {
    border: 1px solid var(--input-focus);
    box-shadow: 0 0 0 3px oklch(from var(--input-focus) l c h / 0.2);
  }

  input:user-invalid {
    border: 1px solid var(--input-error);
    box-shadow: 0 0 0 3px oklch(from var(--input-error) l c h / 0.12);
  }

  .newsletter-status {
    position: relative;
    font-weight: var(--font-weight-semibold);
    color: var(--text-title);
  }

  .newsletter-status:empty {
    display: none;
  }

  .newsletter-status.is-error {
    color: var(--input-error);
  }

  .fine-print {
    font-size: var(--font-01);
    color: var(--text-muted);
  }

  .fine-print-link {
    color: var(--text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .fine-print-link:hover {
    color: var(--text-link);
  }

  .fine-print-link:focus-visible {
    outline: var(--focus-ring);
    outline-offset: 2px;
    border-radius: var(--br-01);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  @media (max-width: 48rem) {
    input {
      width: 100%;
      font-size: var(--font-03);
    }

    .newsletter-text-content {
      padding-inline: var(--section-inline);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--sp-03);
    }

    .newsletter-input {
      width: 100%;
      padding-inline: var(--section-inline);
    }

    .weed-leaf {
      position: absolute;
      bottom: -8%;
      right: -45%;
      width: 120%;
      opacity: 0.1;
    }
  }
</style>

<script>
  // Progressive enhancement: submit to Netlify Forms via fetch and confirm
  // inline. Without JS the form falls back to a normal POST that lands on
  // /newsletter/thanks. (Netlify only processes forms on deployed sites,
  // so locally this always shows the error state.)
  const form = document.querySelector('.newsletter-input') as HTMLFormElement
  const status = document.querySelector('.newsletter-status') as HTMLElement
  const button = form.querySelector(
    'button[type="submit"]',
  ) as HTMLButtonElement

  form.addEventListener('submit', async (event) => {
    event.preventDefault()
    const original = button.textContent
    button.disabled = true
    button.textContent = 'Subscribing…'
    status.classList.remove('is-error')
    status.textContent = ''

    try {
      const response = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(
          new FormData(form) as unknown as URLSearchParams,
        ).toString(),
      })
      if (!response.ok) throw new Error(`HTTP ${response.status}`)
      form.hidden = true
      status.textContent = "You're in! Watch your inbox for updates from Dana."
    } catch {
      button.disabled = false
      button.textContent = original
      status.classList.add('is-error')
      status.textContent =
        "Something went wrong — your signup didn't send. Please try again."
    }
  })
</script>
